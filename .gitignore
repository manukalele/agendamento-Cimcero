# ─── Dependências ────────────────────────────────────────────
node_modules/

# ─── Build / Electron Builder ────────────────────────────────
dist/
out/
release/
*.exe
*.dmg
*.AppImage
*.snap
*.deb
*.rpm

# ─── SESSÕES DE AMBIENTE — NUNCA EMPACOTAR ───────────────────
#
# Estes arquivos contêm credenciais de ambiente de teste.
# Se incluídos no bundle, a sessão do desenvolvedor vaza para
# produção e o QR Code nunca aparece para o usuário final.
#
# baileys_session/  → credenciais do WhatsApp (Baileys multifile)
# sessao.json       → cookie PHPSESSID do sistema externo
# .app-version      → marca de versão gerenciada pelo app em runtime
#
baileys_session/
sessao.json
.app-version

# ─── Logs e diagnóstico ──────────────────────────────────────
*.log
boot-error.log
logs/

# ─── Temporários e SO ────────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
*.bak
